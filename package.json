{
  "name": "microbit-v2",
  "version": "1.0.0",
  "author": "ArthurZheng",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openblock-plugin/microbitV2.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "npx openblock-registry-cli dev",
    "build": "npx openblock-registry-cli build",
    "build:obfuscate": "npx openblock-registry-cli build --obfuscate",
    "publish": "npx openblock-registry-cli publish",
    "publish:dry": "npx openblock-registry-cli publish --dry-run",
    "validate": "npx openblock-registry-cli validate",
    "i18n:update": "npx openblock-registry-cli i18n update",
    "lint": "eslint . --ext .js --fix"
  },
  "openblock": {
    "name": "micro:bit V2",
    "deviceId": "microbitV2",
    "manufactor": "microbit",
    "learnMore": "https://microbit.org/new-microbit/",
    "type": "microbit",
    "iconURL": "./assets/microbitV2.png",
    "description": {
      "formatMessage": {
        "id": "microbitV2.description",
        "default": "Upgraded processor, built-In speaker and microphone, touch sensitive logo."
      }
    },
    "bluetoothRequired": false,
    "serialportRequired": true,
    "defaultBaudRate": "115200",
    "internetConnectionRequired": false,
    "launchPeripheralConnectionFlow": true,
    "useAutoScan": false,
    "connectionIconURL": "./assets/microbitV2-illustration.svg",
    "connectionSmallIconURL": "./assets/microbitV2-small.svg",
    "main": "./src/microbitV2.js",
    "generator": "./src/generator.js",
    "translations": "./src/translations.js",
    "programMode": ["upload"],
    "tags": ["microbit"],
    "helpLink": "https://wiki.openblock.cc/general-hardware-guidelines/boards/microbit-v2",
    "libraries": "./libraries"
  },
  "devDependencies": {
    "babel-eslint": "^10.0.1",
    "eslint": "^5.3.0",
    "eslint-config-scratch": "^5.0.0",
    "husky": "^9.0.0"
  }
}
